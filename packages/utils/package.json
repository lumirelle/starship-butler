{
  "name": "starship-butler-utils",
  "type": "module",
  "version": "7.0.1",
  "description": "Utils used by starship butler.",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/starship-butler#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/starship-butler.git"
  },
  "bugs": "https://github.com/lumirelle/starship-butler/issues",
  "keywords": [
    "config-butler",
    "config-manager",
    "starship-butler"
  ],
  "sideEffects": false,
  "exports": {
    "./config": {
      "import": {
        "types": "./dist/config.d.mts",
        "default": "./dist/config.mjs"
      }
    },
    "./path": {
      "import": {
        "types": "./dist/path.d.mts",
        "default": "./dist/path.mjs"
      }
    },
    "./fs": {
      "import": {
        "types": "./dist/fs.d.mts",
        "default": "./dist/fs.mjs"
      }
    },
    "./highlight": {
      "import": {
        "types": "./dist/highlight.d.mts",
        "default": "./dist/highlight.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown --publint --attw.profile esm-only",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "c12": "catalog:prod",
    "consola": "catalog:prod",
    "pathe": "catalog:prod",
    "rc9": "catalog:prod"
  }
}

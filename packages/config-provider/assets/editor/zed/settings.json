// cSpell:disable
{
  // #region UI
  // Theme
  "code_actions_on_format": {
    "source.fixAll.oxc": true
  },
  "theme": {
    "mode": "system",
    "light": "Vitesse Light",
    "dark": "Vitesse Dark"
  },
  "icon_theme": "Catppuccin Mocha",
  // Layout
  "use_system_prompts": false,
  "use_system_path_prompts": false,
  "indent_guides": {
    "coloring": "indent_aware"
  },
  "relative_line_numbers": "enabled",
  "soft_wrap": "editor_width",
  "wrap_guides": [
    100,
    200
  ],
  "show_whitespaces": "boundary",
  "colorize_brackets": true,
  // Font
  "ui_font_family": "Drafting* Mono",
  "ui_font_fallbacks": [
    "Maple Mono CN",
    "Symbols Nerd Font"
  ],
  "ui_font_size": 16,
  "buffer_font_family": "Drafting* Mono",
  "buffer_font_fallbacks": [
    "Maple Mono CN",
    "Symbols Nerd Font Mono"
  ],
  "buffer_font_size": 16,
  "buffer_font_features": {
    "calt": true,
    "liga": true
  },
  // #endregion
  // #region Lens & Hint
  // Hint
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": false
  },
  // #endregion

  // #region Behavior
  // Trust
  "session": {
    "trust_all_worktrees": true
  },
  // Vim Mode
  "vim_mode": true,
  // File Associations
  "file_types": {
    "env": [
      ".env.!(js|ts|mhs|cjs|mts|cts)"
    ]
  },
  // Editor
  "close_on_file_delete": true,
  // Terminal
  "terminal": {
    "shell": {
      "program": "nu"
    }
  },
  // Minimap
  "minimap": {
    "display_in": "all_editors",
    "show": "always"
  },
  // Scroll
  "scroll_sensitivity": 2,
  "fast_scroll_sensitivity": 3,
  // #endregion

  // #region Code Quality
  "formatter": [
    { "language_server": { "name": "oxlint" } }
  ],
  "format_on_save": "on"
  // #endregion
}

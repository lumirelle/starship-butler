[
  // #region Basic
  // Tab completion
  // Disable tab for editor suggestions, use <enter> only.
  {
    "key": "tab",
    "command": "-acceptSelectedSuggestion",
    "when": "suggestWidgetHasFocusedSuggestion && suggestWidgetVisible && textInputFocus"
  },
  {
    "key": "tab",
    "command": "-workbench.action.terminal.acceptSelectedSuggestion",
    "when": "simpleSuggestWidgetHasFocusedSuggestion && terminalFocus && terminalHasBeenCreated && terminalIsOpen && terminalSuggestWidgetVisible || simpleSuggestWidgetHasFocusedSuggestion && terminalFocus && terminalIsOpen && terminalProcessSupported && terminalSuggestWidgetVisible"
  },
  // Refine tab for inline suggestions in user scope, to make it higher priority.
  {
    "key": "tab",
    "command": "-editor.action.inlineSuggest.commit",
    "when": "inlineEditIsVisible && tabShouldAcceptInlineEdit && !editorHoverFocused && !editorTabMovesFocus && !suggestWidgetVisible || inlineEditIsVisible && inlineSuggestionVisible && tabShouldAcceptInlineEdit && !editorHoverFocused && !editorTabMovesFocus && !suggestWidgetVisible || inlineSuggestionHasIndentationLessThanTabSize && inlineSuggestionVisible && !editor.hasSelection && !editorHoverFocused && !editorTabMovesFocus && !suggestWidgetVisible || inlineEditIsVisible && inlineSuggestionHasIndentationLessThanTabSize && inlineSuggestionVisible && !editor.hasSelection && !editorHoverFocused && !editorTabMovesFocus && !suggestWidgetVisible"
  },
  {
    "key": "tab",
    "command": "editor.action.inlineSuggest.commit",
    "when": "inlineEditIsVisible && tabShouldAcceptInlineEdit && !editorHoverFocused && !editorTabMovesFocus && !suggestWidgetVisible || inlineEditIsVisible && inlineSuggestionVisible && tabShouldAcceptInlineEdit && !editorHoverFocused && !editorTabMovesFocus && !suggestWidgetVisible || inlineSuggestionHasIndentationLessThanTabSize && inlineSuggestionVisible && !editor.hasSelection && !editorHoverFocused && !editorTabMovesFocus && !suggestWidgetVisible || inlineEditIsVisible && inlineSuggestionHasIndentationLessThanTabSize && inlineSuggestionVisible && !editor.hasSelection && !editorHoverFocused && !editorTabMovesFocus && !suggestWidgetVisible"
  },
  // Terminal
  // Confuse with browser's inspect element shortcut and not so useful, so disable it.
  {
    "key": "ctrl+shift+c",
    "command": "-workbench.action.terminal.openNativeConsole",
    "when": "!terminalFocus"
  },
  // #endregion

  // #region With Neovim (When Editor Not Focused)
  // Session
  // Use space+q+q to close session, to be consistent with Neovim + Lazyvim.
  {
    "key": "space q q",
    "command": "workbench.action.closeWindow",
    "when": "!editorFocus && !inputFocus && !terminalFocus"
  },
  // Workbench
  // Use space+z to toggle VSCode zen mode.
  {
    "key": "space z",
    "command": "workbench.action.toggleZenMode",
    "when": "!editorFocus && !inputFocus && !terminalFocus"
  },
  // Popup
  // Use space+space to open file explorer, to be consistent with Neovim + Lazyvim.
  {
    "key": "space space",
    "command": "workbench.action.quickOpen",
    "when": "!editorFocus && !inputFocus && !terminalFocus"
  },
  // Use space+backspace to open folder, enhance DX.
  {
    "key": "space backspace",
    "command": "workbench.action.files.openFolder",
    "when": "!editorFocus && !inputFocus && !terminalFocus"
  },
  // Sidebar
  // Use space+e / space+shift+e to toggle sidebar/auxiliary bar, to be consistent with Neovim + Lazyvim.
  {
    "key": "ctrl+b",
    "command": "-workbench.action.toggleSidebarVisibility"
  },
  {
    "key": "space e",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "!editorFocus && !inputFocus && !terminalFocus && sideBarVisible"
  },
  {
    "key": "space e",
    "command": "workbench.action.focusSideBar",
    "when": "!editorFocus && !inputFocus && !terminalFocus && !sideBarVisible"
  },
  {
    "key": "ctrl+alt+b",
    "command": "-workbench.action.toggleAuxiliaryBar"
  },
  {
    "key": "space shift+e",
    "command": "workbench.action.toggleAuxiliaryBar",
    "when": "!editorFocus && !inputFocus && !terminalFocus && auxiliaryBarVisible"
  },
  {
    "key": "space shift+e",
    "command": "workbench.action.toggleAuxiliaryBar",
    "when": "!editorFocus && !inputFocus && !terminalFocus && !auxiliaryBarVisible"
  },
  {
    "key": "ctrl+pagedown",
    "command": "workbench.action.nextSideBarView",
    "when": "sideBarFocus"
  },
  {
    "key": "ctrl+pageup",
    "command": "workbench.action.previousSideBarView",
    "when": "sideBarFocus"
  },
  // Window navigation
  // Use ctrl+h/j/k/l for window navigation, to be consistent with Neovim + Lazyvim.
  {
    "key": "ctrl+h",
    "command": "workbench.action.navigateLeft"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.navigateUp"
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.navigateDown"
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.navigateRight"
  },
  // Tab navigation
  // Free up ctrl+pageup/pagedown for sidebar navigation, use HJKL to be consistent with Neovim + Lazyvim.
  {
    "key": "ctrl+pageup",
    "command": "-workbench.action.previousEditor"
  },
  {
    "key": "ctrl+pagedown",
    "command": "-workbench.action.nextEditor"
  },
  // Editor Size
  // Use ctrl+arrow keys to resize editor, to be consistent with Neovim + Lazyvim.
  {
    "key": "ctrl+down",
    "command": "workbench.action.decreaseViewHeight",
    "when": "editorFocus && !isAuxiliaryWindowFocusedContext && !terminalFocus && neovim.mode != 'cmdline'"
  },
  {
    "key": "ctrl+up",
    "command": "workbench.action.increaseViewHeight",
    "when": "editorFocus && !isAuxiliaryWindowFocusedContext && !terminalFocus && neovim.mode != 'cmdline'"
  },
  {
    "key": "ctrl+left",
    "command": "workbench.action.decreaseViewWidth",
    "when": "editorFocus && !isAuxiliaryWindowFocusedContext && !terminalFocus && neovim.mode != 'cmdline'"
  },
  {
    "key": "ctrl+right",
    "command": "workbench.action.increaseViewWidth",
    "when": "editorFocus && !isAuxiliaryWindowFocusedContext && !terminalFocus && neovim.mode != 'cmdline'"
  },
  // Scroll
  // Use ctrl+e/y for scrolling line, to be consistent with Neovim + Lazyvim.
  {
    "key": "ctrl+e",
    "command": "scrollLineDown",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+y",
    "command": "scrollLineUp",
    "when": "editorTextFocus"
  },
  // Move line
  // Use alt+j/k to move line down/up, to be consistent with Neovim + Lazyvim.
  {
    "key": "alt+j",
    "command": "editor.action.moveLinesDownAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "alt+k",
    "command": "editor.action.moveLinesUpAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  // Undo breakpoints
  // Workaround to trigger undo breakpoint for Neovim in VSCode.
  // Disable when has selection or multiple cursors, because these will break them.
  {
    "key": "space",
    "command": "vscode-neovim.send",
    "when": "editorTextFocus && neovim.init && neovim.mode == 'insert' && !editorHasSelection && !editorHasMultipleSelections",
    "args": " "
  },
  {
    "key": "oem_comma",
    "command": "vscode-neovim.send",
    "when": "editorTextFocus && neovim.init && neovim.mode == 'insert' && !editorHasSelection && !editorHasMultipleSelections",
    "args": ","
  },
  {
    "key": "oem_period",
    "command": "vscode-neovim.send",
    "when": "editorTextFocus && neovim.init && neovim.mode == 'insert' && !editorHasSelection && !editorHasMultipleSelections",
    "args": "."
  },
  {
    "key": "oem_1",
    "command": "vscode-neovim.send",
    "when": "editorTextFocus && neovim.init && neovim.mode == 'insert' && !editorHasSelection && !editorHasMultipleSelections",
    "args": ";"
  },
  // Terminal
  // Use ctrl+/ to toggle terminal, to be consistent with Neovim + Lazyvim.
  {
    "key": "ctrl+`",
    "command": "-workbench.action.terminal.toggleTerminal",
    "when": "terminal.active && terminalFocus"
  },
  {
    "key": "ctrl+shift+oem_3",
    "command": "-workbench.action.terminal.new",
    "when": "terminalProcessSupported || terminalWebExtensionContributedProfile"
  },
  {
    "key": "ctrl+/",
    "command": "workbench.action.terminal.toggleTerminal",
    "when": "terminal.active"
  },
  // XXX(Lumirelle): Get a consistent experience with Neovim + Lazyvim.
  {
    "key": "ctrl+shift+/",
    "command": "workbench.action.terminal.new",
    "when": "terminalProcessSupported || terminalWebExtensionContributedProfile"
  }
  // #endregion
]

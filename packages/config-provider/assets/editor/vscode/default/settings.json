    "*.razor": "$(capture).razor.cs, $(capture).razor.css, $(capture).razor.scss",
    "*.resx": "$(capture).*.resx, $(capture).designer.cs, $(capture).designer.vb",
    "*.tex": "$(capture).acn, $(capture).acr, $(capture).alg, $(capture).aux, $(capture).bbl, $(capture).bbl-SAVE-ERROR, $(capture).bcf, $(capture).bib, $(capture).blg, $(capture).fdb_latexmk, $(capture).fls, $(capture).glg, $(capture).glo, $(capture).gls, $(capture).idx, $(capture).ind, $(capture).ist, $(capture).lof, $(capture).log, $(capture).lot, $(capture).nav, $(capture).out, $(capture).run.xml, $(capture).snm, $(capture).synctex.gz, $(capture).toc, $(capture).xdv",
    "*.ts": "$(capture).js, $(capture).d.ts.map, $(capture).*.ts, $(capture)_*.js, $(capture)_*.ts",
    "*.tsx": "$(capture).ts, $(capture).*.ts, $(capture).*.tsx, $(capture)_*.ts, $(capture)_*.tsx, $(capture).css, $(capture).module.css, $(capture).less, $(capture).module.less, $(capture).module.less.d.ts, $(capture).scss, $(capture).module.scss, $(capture).module.scss.d.ts, $(capture).css.ts",
    "*.vbproj": "*.config, *proj.user, appsettings.*, bundleconfig.json",
    "*.vue": "$(capture).*.ts, $(capture).*.js, $(capture).story.vue",
    "*.w": "$(capture).*.w, I$(capture).w",
    "*.wat": "$(capture).wasm",
    "*.xaml": "$(capture).xaml.cs"
  },
  "fileNestingUpdater.autoUpdate": true,
  // #endregion

  // #region Appearance / Sidebar / Source Control
  // Built-in
  // We use extension "eamodio.gitlensinstead" instead, because it respects .git-blame-ignore-revs without extra configuration.
  "git.blame.editorDecoration.enabled": false,
  "git.blame.statusBarItem.enabled": false,
  // GitLens
  "gitlens.defaultCurrentUserNameStyle": "nameAndYou",
  "gitlens.graph.dimMergeCommits": true,
  "gitlens.launchpad.indicator.enabled": false,
  "gitlens.views.scm.grouped.hiddenViews": { "worktrees": true },
  "gitlens.views.formats.commits.label": "${(tips|11?) > }${message}",
  // #endregion

  // #region Appearance / Editor
  // Line Numbers & Guides
  "editor.lineNumbers": "relative",
  "scm.diffDecorationsGutterWidth": 2,
  "editor.renderWhitespace": "boundary",
  "editor.guides.bracketPairs": true,
  "editor.rulers": [80, 120, 200],
  // Cursor
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  // Lens
  "errorLens.enabledDiagnosticLevels": ["warning", "error", "info", "hint"],
  "errorLens.messageTemplate": "[$count] $severity $message $source($code)",
  // Hint
  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "js/ts.inlayHints.parameterNames.enabled": "all",
  "js/ts.inlayHints.parameterTypes.enabled": true,
  "vue.inlayHints.destructuredProps": true,
  "vue.inlayHints.inlineHandlerLeading": true,
  "vue.inlayHints.missingProps": true,
  "vue.inlayHints.optionsWrapper": true,
  "vue.suggest.defineAssignment": true,
  "iconify.includes": [], // Include no icon sets by default, should be manually configured by users if needed.
  // #endregion

  // #region Appearance / Highlight
  "workbench.editor.highlightModifiedTabs": true,
  "todohighlight.include": [
    // Scripts
    "**/*.sh",
    "**/*.bat",
    "**/*.ps1",
    "**/*.lua",
    "**/*.nu",
    // Front-end Ecosystem
    "**/*.{,m,c}{j,t}s{,x}",
    "**/*.vue",
    "**/*.svelte",
    "**/*.htm{,l}",
    "**/*.{c,sc,le}ss",
    // Back-end Ecosystem
    "**/*.zig",
    "**/*.rs",
    "**/*.go",
    "**/*.java",
    "**/*.kt",
    "**/*.py",
    "**/*.php",
    "**/*.sql",
    // DevOps Ecosystem
    "**/{d,D}ockerfile",
    // Data & Configurations
    "**/*.{x,y,ya,to}ml",
    "**/*.json{,c}",
    "**/.*rc",
    // Texts
    "**/*.md{,c,x}",
    "**/*.txt"
  ],
  "todohighlight.exclude": [
    // Dotfolders
    "**/.git/**",
    "**/.github/**",
    "**/.vscode/**",
    "**/.output/**",
    "**/.nuxt/**",
    "**/.next/**",
    "**/.pnpm/**",
    "**/.yarn/**",
    // Dependency & Dist Folders
    "**/node_modules/**",
    "**/bower_components/**",
    "**/dist/**",
    "**/out/**",
    "**/logs/**",
    "**/temp/**",
    "**/public/**",
    // Dependency & Dist Files
    "**/*.min.*",
    "**/*.map",
    "**/*.snap",
    "**/package-lock.json",
    "**/pnpm-lock.yaml",
    "**/yarn.lock",
    "**/bun.lock",
    "**/aube-lock.yaml"
  ],
  "todohighlight.defaultStyle": { "color": "#fff", "borderRadius": "8px" },
  "todohighlight.keywords": [
    // Uncompleted tasks.
    {
      "text": "TODO(string):",
      "regex": { "pattern": "(?<=^|\"|\\s)(TODO)(\\(\\w+\\))?:" },
      "backgroundColor": "#3271ae",
      "overviewRulerColor": "rgb(50 113 174 / 80%)"
    },
    {
      "text": "[ ]",
      "backgroundColor": "#3271ae",
      "overviewRulerColor": "rgb(50 113 174 / 80%)"
    },
    // Completed tasks.
    {
      "text": "[x]",
      "backgroundColor": "#68945c",
      "overviewRulerColor": "rgb(104 148 92 / 80%)"
    },
    // Possible to be optimized or improved.
    {
      "text": "XXX(string):",
      "regex": { "pattern": "(?<=^|\"|\\s)(XXX)(\\(\\w+\\))?:" },
      "backgroundColor": "#e18a3b",
      "overviewRulerColor": "rgb(225 138 59 / 80%)"
    },
    // Need to be fixed or rewritten.
    {
      "text": "FIXME(string):",
      "regex": { "pattern": "(?<=^|\"|\\s)(FIXME)(\\(\\w+\\))?:" },
      "backgroundColor": "#ab372f",
      "overviewRulerColor": "rgb(171 55 47 / 80%)"
    },
    // Some notices or hints.
    {
      "text": "NOTE(string):",
      "regex": { "pattern": "(?<=^|\"|\\s)(NOTE|NOTICE)(\\(\\w+\\))?:" },
      "backgroundColor": "#cf929e",
      "overviewRulerColor": "rgb(207 146 158 / 80%)"
    }
  ],
  // #endregion

  // #region Appearance / Custom UI
  "custom-ui-style.external.imports": [
    "file://${userHome}/.vscode/extensions/30d98f9b2.neovide-cursor-1.0.1/neovide-cursor.js"
  ],
  // #endregion

  // #region Behavior / Security
  "security.workspace.trust.enabled": false,
  // #endregion

  // #region Behavior / Profile
  "window.newWindowProfile": "Default",
  // #endregion

  // #region Behavior / Sidebar / Explorer
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.copyPathSeparator": "/",
  "explorer.copyRelativePathSeparator": "/",
  // #endregion

  // #region Behavior / Sidebar / Search
  "search.showLineNumbers": true,
  "search.exclude": {
    // Dotfolders
    "**/.git": true,
    "**/.output": true,
    "**/.nuxt": true,
    "**/.next": true,
    "**/.pnpm": true,
    "**/.yarn": true,
    // Dependency & Dist Folders
    "**/node_modules": true,
    "**/bower_components": true,
    "**/dist": true,
    "**/out": true,
    "**/logs": true,
    "**/temp": true,
    "**/public": true,
    // Dependency & Dist Files
    "**/*.min.*": true,
    "**/*.map": true,
    "**/*.snap": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/yarn.lock": true,
    "**/bun.lock": true,
    "**/aube-lock.yaml": true,
    // Extra Files
    "**/*.svg": true,
    "**/CHANGELOG*": true,
    "**/LICENSE*": true
  },
  // #endregion

  // #region Behavior / Sidebar / Source Control
  "git.autofetch": true,
  "git.confirmSync": true,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "always",
  // #endregion

  // #region Behavior / Editor
  // Startup
  "workbench.startupEditor": "none",
  // Accessibility
  "editor.accessibilitySupport": "off",
  // Open Editor Limits
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.perEditorGroup": true,
  "workbench.editor.limit.value": 5,
  // Word Wrap
  "editor.wordWrap": "on",
  // Minimap
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": false,
  // Suggestions & Emmet
  "editor.acceptSuggestionOnCommitCharacter": false,
  // Fucking Microsoft, why you set "other" to "offWhenInlineCompletions" by default since 1.121?
  // Just because the fucking AI inline suggestions?
  "editor.quickSuggestions": { "other": "on", "comments": "off", "strings": "off" },
  "emmet.syntaxProfiles": { "html": { "filters": "bem" } },
  "emmet.triggerExpansionOnTab": false,
  "editor.unusualLineTerminators": "auto",
  // Zoom
  "editor.mouseWheelZoom": true,
  // Goto
  "editor.gotoLocation.multipleDefinitions": "goto",
  // Diff Editor
  "diffEditor.ignoreTrimWhitespace": false,
  // #endregion

  // #region Behavior / Terminal
  "terminal.integrated.profiles.linux": { "nushell": { "path": "nu" } },
  "terminal.integrated.profiles.osx": { "nushell": { "path": "nu" } },
  "terminal.integrated.profiles.windows": { "nushell": { "path": "nu" } },
  "terminal.integrated.defaultProfile.linux": "nushell",
  "terminal.integrated.defaultProfile.osx": "nushell",
  "terminal.integrated.defaultProfile.windows": "nushell",
  // "terminal.integrated.agentHostProfile.linux": "Command Prompt",
  // "terminal.integrated.agentHostProfile.osx": "Command Prompt",
  "terminal.integrated.agentHostProfile.windows": "Command Prompt",
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.rightClickBehavior": "default",
  "terminal.integrated.shellIntegration.history": 9999,
  // #endregion

  // #region Behavior / Scroll
  "workbench.list.mouseWheelScrollSensitivity": 2,
  "editor.mouseWheelScrollSensitivity": 2,
  "terminal.integrated.mouseWheelScrollSensitivity": 2,
  "workbench.list.fastScrollSensitivity": 3,
  "editor.fastScrollSensitivity": 3,
  "terminal.integrated.fastScrollSensitivity": 3,
  "workbench.list.smoothScrolling": true,
  "editor.smoothScrolling": true,
  "terminal.integrated.smoothScrolling": true,
  // #endregion

  // #region Behavior / Zen Mode
  "zenMode.hideLineNumbers": false,
  // #endregion

  // #region Behavior / AI
  "git.addAICoAuthor": "chatAndAgent",
  "github.copilot.enable": {
    "*": true,
    "markdown": true,
    "plaintext": false,
    "scminput": false,
    "dotenv": false
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "cursor.cpp.disabledLanguages": ["plaintext", "dotenv"],
  // #endregion

  // #region Behavior / Dev Experience
  // Markdown
  "markdown.extension.italic.indicator": "_",
  // Mise
  "mise.autoDetectMiseBinPath": false,
  // Dev Containers
  "containers.containerClient": "com.microsoft.visualstudio.containers.podman",
  "containers.orchestratorClient": "com.microsoft.visualstudio.orchestrators.podmancompose",
  // Vue
  "vue.autoInsert.dotValue": true,
  "vue.hover.rich": true,
  "nuxtr.vueFiles.firstTag": "script",
  "nuxtr.vueFiles.style.addStyleTag": false, // Atomic CSS frameworks are more recommended.
  "nuxtr.piniaFiles.defaultTemplate": "setup",
  // I18n
  "i18n-ally.autoDetection": false,
  "i18n-ally.displayLanguage": "en",
  // #endregion

  // #region Behavior / Extensions / Cleanliness
  "console-ninja.featureSet": "Community",
  "gitlens.plusFeatures.enabled": false,
  "gitlens.cloudPatches.enabled": false,
  "rest-client.enableTelemetry": false,
  // #endregion

  // #region Behavior / Lint
  "cSpell.allowCompoundWords": true,
  "cSpell.customDictionaries": {
    "common": {
      "name": "common",
      "path": "~/.cspell.common.txt",
      "description": "Words used in common situation.",
      "addWords": false
    },
    "work": {
      "name": "work",
      "path": "~/.cspell.work.txt",
      "description": "Words used in work.",
      "addWords": false
    }
  },
  "cSpell.ignorePaths": [
    // Dotfolders
    ".*",
    // Dependency & Dist Folders
    "node_modules",
    "bower_components",
    "dist",
    "out",
    "logs",
    "temp",
    "public",
    // Dependency & Dist Files
    "*.min.*",
    "*.map",
    "*.snap",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "bun.lock",
    "aube-lock.yaml",
    // Extra Files
    "*.svg"
  ],
  // #endregion

  // #region Behavior / Format
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "[shellscript]": { "editor.defaultFormatter": "lumirelle.shell-format-rev" },
  "[properties]": { "editor.defaultFormatter": "lumirelle.shell-format-rev" },
  "[dotenv]": { "editor.defaultFormatter": "lumirelle.shell-format-rev" },
  "[ignore]": { "editor.defaultFormatter": "lumirelle.shell-format-rev" },
  "[dockerfile]": { "editor.defaultFormatter": "ms-azuretools.vscode-containers" },
  "editor.formatOnSave": true,
  "oxc.fixKind": "safe_fix_or_suggestion",
  "markdown.extension.tableFormatter.enabled": false,
  "shellformat.useEditorConfig": true,
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true
  // #endregion
}

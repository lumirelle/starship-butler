# User Information
[user]
# NOTICE: username and email are handled by "~/.gitcloneinit" script.
[credential "https://gitee.com"]
provider = generic

# Core Settings
[core]
ignorecase = false
editor = nvim # Or replace with your preferred editor.
[feature]
# Will enable some default configurations to better handle a large number of files, include "index.version=4".
# See https://git-scm.com/docs/git-config#Documentation/git-config.txt-featuremanyFiles.
manyFiles = true

# Repository Initialization
[init]
defaultBranch = main
templatedir = ~/.config/git/templates

# Working with Branches
[branch]
sort = -committerdate
[diff]
algorithm = histogram
context = 5
[merge]
autostash = true
conflictstyle = zdiff3
ff = no
[rebase]
autostash = true
autosquash = true
# See https://juejin.cn/post/7267567645493674021.
updateRefs = true
[rerere]
enabled = true
[tag]
sort = taggerdate

# Working with Remotes
[fetch]
prune = true
pruneTags = true
[pull]
rebase = true
[push]
autoSetupRemote = true
default = current
followTags = true

# Log
[log]
date = short
decoration = short

# Aliases
# We use -?/--? to trigger the help message for each alias, which is implemented in the corresponding shell function.
[alias]
# @aliasGroup User Info
me = "!f() { \
  echo \"Local identity for $(basename $PWD) is set to \\\"$(git config get user.name) <$(git config get user.email)>\\\".\"; \
}; f"
iam = "!f() { \
  arg_help=false; \
  declare -i value_count=0; \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      *) value_count=value_count+1 ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git iam <user_name> <user_email>'; \
    return 0; \
  fi; \
  \
  if [[ \"$value_count\" -lt 1 ]]; then\
    echo 'Please provide a user name.'; \
    return 1; \
  elif [[ \"$value_count\" -lt 2 ]]; then\
    echo 'Please provide a user email.'; \
    return 1; \
  fi; \
  \
  git config set user.name \"$1\"; \
  git config set user.email \"$2\"; \
  echo \"Local identity for $(basename $PWD) set to \\\"$1 <$2>\\\".\"; \
}; f"
# @aliasGroup Discard
# @alias Discard
# @description Discard changes from specified file path(s).
#   - If a file under this path is tracked, then restore it to the index.
#   - If a file under this path is untracked, then remove it.
# @parameters One or more paths.
discard = "!f() { \
  arg_help=false; \
  declare -i value_count=0; \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      *) value_count=value_count+1 ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git discard <...path>'; \
    return 0; \
  fi; \
  \
  if [[ \"$value_count\" -eq 0 ]]; then \
    echo 'Nothing specified, nothing discarded.'; \
    YELLOW='\\e[0;33m'; \
    NC='\\e[0m'; \
    echo -e \"${YELLOW}hint: Maybe you wanted to say 'git discard .'?${NC}\"; \
    return 0; \
  fi; \
  \
  for path in \"$@\"; do \
    if git ls-files --error-unmatch -- \"$path\" >/dev/null 2>&1; then \
      if git restore --staged --worktree -- \"$path\" >/dev/null 2>&1; then \
        echo \"Restoring tracked file(s) from path: $path\"; \
      fi; \
    fi; \
    if [[ -e \"$path\" ]]; then \
      if git clean -fd -- \"$path\" >/dev/null 2>&1; then \
        echo \"Removing untracked file(s) from path: $path\"; \
      fi; \
    else \
      echo \"Path does not exist: $path\"; \
    fi; \
  done; \
}; f"
x = discard
# @aliasGroup Add & Unadd
a = add
unadd = "!f() { \
  arg_help=false; \
  declare -i value_count=0; \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      *) value_count=value_count+1 ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git unadd <...path>'; \
    return 0; \
  fi; \
  \
  if [[ \"$value_count\" -eq 0 ]]; then \
    echo 'Nothing specified, nothing unadded.'; \
    YELLOW='\\e[0;33m'; \
    NC='\\e[0m'; \
    echo -e \"${YELLOW}hint: Maybe you wanted to say 'git unadd .'?${NC}\"; \
    return 0; \
  fi; \
  \
  git reset HEAD -- \"$@\"; \
}; f"
ua = unadd
# @aliasGroup Commit & Uncommit
# Notice, "commit -m '123' -m '456'" will create a commit with message '123\n\n456'.
commitx = "!f() {\
  arg_help=false; \
  arg_command=commit; \
  values=(); \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -a|--amend) arg_command=\"commit --amend --no-edit\" ;; \
      -e|--edit) arg_command=\"commit --amend\" ;; \
      *) values+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git commitx [options] [message]'; \
    echo '   Or: git commitx --amend [other_options]'; \
    echo '   Or: git commitx --edit [other_options] [message]'; \
    echo 'Options:'; \
    echo '  -a, --amend     Amend the previous commit with the new changes and reuse the previous commit message.'; \
    echo '  -e, --edit      Amend the previous commit with the new changes and edit the previous commit message.'; \
    echo '  ... See \"git commit --help\" for more options.'; \
    return 0; \
  fi; \
  \
  git $arg_command \"${values[@]}\"; \
}; f"
c = commitx
commitx-with-message = "!f() {\
  arg_help=false; \
  arg_command=\"commitx --message\"; \
  arg_not_allow_amend=false; \
  values=(); \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -e|--edit) arg_command=\"commitx --edit --message\" ;; \
      -a|--amend) arg_not_allow_amend=true ;; \
      *) values+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git commitx-with-message <msg_category> [msg_scope] <msg_subject_and_body> [options]'; \
    echo '   Or: git commitx-with-message --edit [other_options]'; \
    echo 'Options:'; \
    echo '  -e, --edit     Amend the previous commit with the new changes and edit the previous commit message.'; \
    echo '  ... See \"git commitx --?\" for more options.'; \
    return 0; \
  fi; \
  \
  if \"$arg_not_allow_amend\"; then \
    echo 'Cannot use --amend option together with command \"commitx-with-message\".';\
    echo 'Command \"commitx-with-message\" is designed to always require a new commit message, while --amend is used to reuse the previous commit message. They are conflicting.'; \
    return 1; \
  fi; \
  \
  has_breaking_change=false; \
  if [[ ${values[0]} == *! ]]; then \
    has_breaking_change=true; \
    values[0]=${values[0]//!/}; \
  fi; \
  \
  if [[ ${#values[@]} -ge 3 ]]; then \
    git $arg_command \"${values[0]}(${values[1]})$([[ "$has_breaking_change" == true ]] && echo "!"): ${values[2]}\" \"${values[@]:3}\"; \
  elif [[ ${#values[@]} -eq 2 ]]; then \
    git $arg_command \"${values[0]}$([[ "$has_breaking_change" == true ]] && echo "!"): ${values[1]}\"; \
  else \
    echo 'Please provide a valid conventional commit message.'; \
    return 1; \
  fi; \
}; f"
cm = commitx-with-message
uncommit = reset --soft HEAD^ # Back to the staging area
uc = uncommit
commit-work-in-progress = "!git commitx-with-message feat wip"
cwip = commit-work-in-progress
commit-readme = "!git commitx-with-message docs 'update README.md'"
creadme = commit-readme
commit-dependencies = "!git commitx-with-message chore 'update non-major dependencies'"
cdep = commit-dependencies
commit-snapshots = "!git commitx-with-message test 'update snapshots'"
csnap = commit-snapshots
# @aliasGroup Work with Branches
b = branch
# @alias Branch Delete
# @description Delete branch with more flexible options.
# @parameters One branch name and optional flags:
#   - "-o" or "--origin": Delete the branch from origin remote only.
#   - "-a" or "--all": Delete the branch from both local and origin remote.
#   - "-f" or "--force": Force delete the local branch.
#   - If neither "-o" / "--origin" nor "-a" / "--all" is provided, delete the branch from local only.
branch-delete = "!f() { \
  arg_help=false; \
  arg_range=local; \
  arg_force=false; \
  branches=(); \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -o|--origin) arg_range=origin ;; \
      -a|--all) arg_range=all ;; \
      -f|--force) arg_force=true ;; \
      *) branches+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git branch-delete [options] <...branch_name>'; \
    echo 'Options:'; \
    echo '  -o, --origin    Delete the branch from origin remote only.'; \
    echo '  -a, --all       Delete the branch from both local and origin remote.'; \
    echo '  -f, --force     Force delete the local branch.'; \
    return 0; \
  fi; \
  \
  if [[ ${#branches[@]} -eq 0 ]]; then \
    echo 'Please provide a branch name to delete.'; \
    return 1; \
  fi; \
  \
  for branch_name in \"${branches[@]}\"; do \
    if [[ \"$arg_range\" == all ]]; then \
      if [[ \"$arg_force\" == true ]]; then \
        git branch --delete --force \"$branch_name\"; \
      else \
        git branch --delete \"$branch_name\"; \
      fi; \
      git push origin \":refs/heads/$branch_name\"; \
    elif [[ \"$arg_range\" == origin ]]; then \
      git push origin \":refs/heads/$branch_name\"; \
    else \
      if [[ \"$arg_force\" == true ]]; then \
        git branch --delete --force \"$branch_name\"; \
      else \
        git branch --delete \"$branch_name\"; \
      fi; \
    fi; \
  done; \
}; f"
bx = branch-delete
# @aliasGroup Stash
stashx = "!f() { \
  arg_help=false; \
  arg_command=stash; \
  values=(); \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -l|--list) arg_command=\"stash list\" ;; \
      -s|--show) arg_command=\"stash show\" ;; \
      -a|--apply) arg_command=\"stash apply\" ;; \
      -p|--pop) arg_command=\"stash pop\" ;; \
      -x|--drop) arg_command=\"stash drop\" ;; \
      *) values+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git stashx [options] [message]'; \
    echo 'Options:'; \
    echo '  -l, --list      List all stashes.'; \
    echo '  -s, --show      Show the changes recorded in the stash as a diff between the stashed state and its original parent.'; \
    echo '  -a, --apply     Apply the changes recorded in the stash to the working directory.'; \
    echo '  -p, --pop       Apply the changes recorded in the stash to the working directory and remove the stash from the stash list.'; \
    echo '  -x, --drop      Remove a single stash from the stash list.'; \
    echo '  ... See \"git $arg_command --help\" for more options.'; \
    return 0; \
  fi; \
  \
  git $arg_command \"${values[@]}\"; \
}; f"
s = stashx
# @aliasGroup Switch
w = switch
# @aliasGroup Merge
# Notice, like commit, multiple "-m" options will be concatenated with "\n\n" as separator to form the final merge commit message.
mergex = "!f() { \
  arg_help=false; \
  arg_command=\"merge --no-ff\"; \
  values=(); \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -z|--abort) arg_command=\"merge --abort\" ;; \
      -c|--continue) arg_command=\"merge --continue\" ;; \
      *) values+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git mergex [options] [commit]'; \
    echo '   Or: git mergex --abort'; \
    echo '   Or: git mergex --continue'; \
    echo 'Options:'; \
    echo '  -z, --abort     Abort the merge operation.'; \
    echo '  -c, --continue  Continue the merge operation.'; \
    echo '  ... See \"git merge --help\" for more options.'; \
    return 0; \
  fi; \
  \
  if [[ \"$arg_command\" == \"merge --no-ff\" ]]; then \
    current_branch=$(git branch --show-current); \
    merge_branches=$(echo ${values[*]} | awk -v OFS=\", \" '{ $1=$1; print }'); \
    if git $arg_command --message \"chore: merge $merge_branches into $current_branch\" \"$@\"; then \
      echo \"Merging \"$merge_branches\" into current $current_branch with default message...\"; \
    fi; \
  else \
    git $arg_command; \
  fi; \
}; f"
m = mergex
# @aliasGroup Rebase
rebasex = "!f() { \
  arg_help=false; \
  arg_command=\"rebase\"; \
  rebase_branch=\"\"; \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -z|--abort) arg_command=\"rebase --abort\" ;; \
      -c|--continue) arg_command=\"rebase --continue\" ;; \
      *) rebase_branch=\"$arg\" ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git rebasex [options] [commit]'; \
    echo '   Or: git rebasex --abort'; \
    echo '   Or: git rebasex --continue'; \
    echo 'Options:'; \
    echo '  -z, --abort     Abort the rebase operation.'; \
    echo '  -c, --continue  Continue the rebase operation.'; \
    echo '  ... See \"git rebase --help\" for more options.'; \
    return 0; \
  fi; \
  \
  if [[ \"$arg_command\" == \"rebase\" ]]; then \
    git $arg_command \"${values[@]}\"; \
  else \
    git $arg_command; \
  fi; \
}; f"
n = rebasex
# @aliasGroup Reset
rs = reset
# @aliasGroup Revert
revertx = "!f() { \
  arg_help=false; \
  arg_command=\"revert\"; \
  values=(); \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -z|--abort) arg_command=\"revert --abort\" ;; \
      -c|--continue) arg_command=\"revert --continue\" ;; \
      *) values+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git revertx [options] [commit]'; \
    echo '   Or: git revertx --abort'; \
    echo '   Or: git revertx --continue'; \
    echo 'Options:'; \
    echo '  -z, --abort     Abort the revert operation.'; \
    echo '  -c, --continue  Continue the revert operation.'; \
    echo '  ... See \"git revert --help\" for more options.'; \
    return 0; \
  fi; \
  \
  if [[ \"$arg_command\" == \"revert\" ]]; then \
    git $arg_command \"${values[@]}\"; \
  else \
    git $arg_command; \
  fi; \
}; f"
rv = revertx
# @aliasGroup Cherry-pick
cherry-pickx = "!f() { \
  arg_help=false; \
  arg_command=\"cherry-pick\"; \
  values=(); \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -z|--abort) arg_command=\"cherry-pick --abort\" ;; \
      -c|--continue) arg_command=\"cherry-pick --continue\" ;; \
      *) values+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git cherry-pickx [options] [commit]'; \
    echo '   Or: git cherry-pickx --abort'; \
    echo '   Or: git cherry-pickx --continue'; \
    echo 'Options:'; \
    echo '  -z, --abort     Abort the cherry-pick operation.'; \
    echo '  -c, --continue  Continue the cherry-pick operation.'; \
    echo '  ... See \"git cherry-pick --help\" for more options.'; \
    return 0; \
  fi; \
  \
  if [[ \"$arg_command\" == \"cherry-pick\" ]]; then \
    git $arg_command \"${values[@]}\"; \
  else \
    git $arg_command; \
  fi; \
}; f"
cp = cherry-pickx
# @aliasGroup Tag
tagx = "!f() { \
  arg_help=false; \
  declare -i arg_count=0; \
  values=(); \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -a|--annotate|-m|--message) arg_count=arg_count+1 ;; \
      -*|--*) arg_count=arg_count+1; values+=(\"$arg\") ;; \
      *) values+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git tagx [options] <tag_name> [<tag_message>]'; \
    echo 'Options:'; \
    echo '  ... See \"git tag --help\" for more options.'; \
    return 0; \
  fi; \
  \
  if [[ \"$arg_count\" -eq 0 ]]; then \
    if [[ ${#values[@]} -ge 2 ]]; then \
      git tag --annotate \"${values[0]}\" --message \"${values[@]}\"; \
    elif [[ ${#values[@]} -eq 1 ]]; then  \
      git tag --annotate \"${values[0]}\" --message \"${values[0]}\"; \
    fi; \
  else \
    git tag \"${values[@]}\"; \
  fi; \
}; f"
t = tagx
tag-delete = "!f() { \
  arg_help=false; \
  arg_range=local; \
  tags=(); \
  \
  for arg in \"$@\"; do \
    case $arg in \
      -\\?|--\\?) arg_help=true ;; \
      -o|--origin) arg_range=origin ;; \
      -a|--all) arg_range=all ;; \
      *) tags+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git tag-delete [options] <tag_name>'; \
    echo '   Or: git tag-delete --origin <tag_name>'; \
    echo '   Or: git tag-delete --all <tag_name>'; \
    echo 'Options:'; \
    echo '  -o, --origin    Delete the tag from origin remote only.'; \
    echo '  -a, --all       Delete the tag from both local and origin remote.'; \
    return 0; \
  fi; \
  \
  if [[ ${#tags[@]} -eq 0 ]]; then \
    echo 'Please provide a tag name to delete.'; \
    return 1; \
  fi; \
  \
  for tag_name in \"${tags[@]}\"; do \
    if [[ \"$arg_range\" == "all" ]]; then \
      git tag --delete \"$tag_name\"; \
      git push origin \":refs/tags/$tag_name\"; \
    elif [[ \"$arg_range\" == "origin" ]]; then \
      git push origin \":refs/tags/$tag_name\"; \
    else \
      git tag --delete \"$tag_name\"; \
    fi; \
  done; \
}; f"
tx = tag-delete
# @aliasGroup Remote
remotex = "!f() { \
  arg_help=false; \
  subcommand=\"\"; \
  values=(); \
  \
  for arg in \"$@\"; do \
    case $arg in \
      -\\?|--\\?) arg_help=true ;; \
      -a|--add) subcommand=\"add\" ;; \
      -x|--remove) subcommand=\"remove\" ;; \
      *) values+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git remotex [subcommand] [options]'; \
    echo '   Or: git remotex --add [remote_name:-origin] <remote_url>'; \
    echo '   Or: git remotex --remove <remote_name>'; \
    echo 'Options:'; \
    echo '  -a, --add       Add a new remote.'; \
    echo '  -x, --remove    Remove a remote.'; \
    return 0; \
  fi; \
  \
  if [[ \"$subcommand\" == "add" ]]; then \
    if [[ ${#values[@]} -eq 1 ]]; then \
      git remote add origin \"${values[0]}\"; \
    else \
      git remote add \"${values[@]}\"; \
    fi; \
  elif [[ \"$subcommand\" == "remove" ]]; then \
    git remote remove \"${values[@]}\"; \
  else \
    git remote \"$@\"; \
  fi; \
}; f"
r = remotex
# @aliasGroup Fetch
f = fetch
# @aliasGroup Pull
l = pull
# @aliasGroup Push
p = push
# @aliasGroup Log
graph = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
logs = log HEAD --stat
log1 = log -1 HEAD --stat
# @aliasGroup Aliases
aliases = "!git config --get-regexp ^alias\\. | sed -e s/^alias\\.// -e s/\\ /\\ =\\ /"

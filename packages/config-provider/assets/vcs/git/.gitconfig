# User Information
[user]
# NOTICE: Please replace the following with your own information.
name = Lumirelle
email = shabbyacc@outlook.com
[credential "https://gitee.com"]
provider = generic

# Core Settings
[core]
ignorecase = false
editor = nvim # Or replace with your preferred editor.
[feature]
# Will enable some default configurations to better handle a large number of files, include `index.version=4`.
# See https://git-scm.com/docs/git-config#Documentation/git-config.txt-featuremanyFiles.
manyFiles = true

# Repository Initialization
[init]
defaultBranch = main

# Working with Branches
[branch]
sort = -committerdate
[diff]
algorithm = histogram
context = 5
[merge]
autostash = true
conflictstyle = zdiff3
ff = no
[rebase]
autostash = true
autosquash = true
# See https://juejin.cn/post/7267567645493674021.
updateRefs = true
[rerere]
enabled = true
[tag]
sort = taggerdate

# Working with Remotes
[fetch]
prune = true
pruneTags = true
[pull]
rebase = true
[push]
autoSetupRemote = true
default = current
followTags = true

# Log
[log]
date = short
decoration = short

# Aliases
# We use -?/--? to trigger the help message for each alias, which is implemented in the corresponding shell function.
[alias]
# @aliasGroup User Info
me = "!f() { \
  echo Username: $(git config get user.name); \
  echo Email: $(git config get user.email); \
}; f"
iam = "!f() { \
  arg_help=false; \
  declare -i value_count=0; \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      *) value_count=value_count+1 ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git iam <user-name> <user-email>'; \
    return 0; \
  fi; \
  \
  if [[ \"$value_count\" -lt 1 ]]; then\
    echo 'Please provide a user name.'; \
    return 1; \
  elif [[ \"$value_count\" -lt 2 ]]; then\
    echo 'Please provide a user email.'; \
    return 1; \
  fi; \
  \
  git config set user.name \"$1\"; \
  git config set user.email \"$2\"; \
}; f"
# @aliasGroup Discard
# @alias Discard
# @description Discard changes from specified file path(s).
#   - If a file under this path is tracked, then restore it to the index.
#   - If a file under this path is untracked, then remove it.
# @parameters One or more paths.
discard = "!f() { \
  arg_help=false; \
  declare -i value_count=0; \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      *) value_count=value_count+1 ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git discard <file-path(s)>'; \
    return 0; \
  fi; \
  \
  if [[ \"$value_count\" -eq 0 ]]; then \
    echo 'Nothing specified, nothing discarded.'; \
    YELLOW='\\e[0;33m'; \
    NC='\\e[0m'; \
    echo -e \"${YELLOW}hint: Maybe you wanted to say 'git discard .'?${NC}\"; \
    return 0; \
  fi; \
  \
  for path in \"$@\"; do \
    if git ls-files --error-unmatch -- \"$path\" >/dev/null 2>&1; then \
      if git restore --staged --worktree -- \"$path\" >/dev/null 2>&1; then \
        echo \"Restoring tracked file(s) from path: $path\"; \
      fi; \
    fi; \
    if [[ -e \"$path\" ]]; then \
      if git clean -fd -- \"$path\" >/dev/null 2>&1; then \
        echo \"Removing untracked file(s) from path: $path\"; \
      fi; \
    else \
      echo \"Path does not exist: $path\"; \
    fi; \
  done; \
}; f"
x = discard
# @aliasGroup Add & Unadd
a = add
unadd = "!f() { \
  arg_help=false; \
  declare -i value_count=0; \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      *) value_count=value_count+1 ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git unadd <file-path(s)>'; \
    return 0; \
  fi; \
  \
  if [[ \"$value_count\" -eq 0 ]]; then \
    echo 'Nothing specified, nothing unadded.'; \
    YELLOW='\\e[0;33m'; \
    NC='\\e[0m'; \
    echo -e \"${YELLOW}hint: Maybe you wanted to say 'git unadd .'?${NC}\"; \
    return 0; \
  fi; \
  \
  git reset HEAD -- \"$@\"; \
}; f"
ua = unadd
# @aliasGroup Commit & Uncommit
# Notice, `commit -m '123' -m '456'` will create a commit with message '123\n\n456'.
commitx = "!f() {\
  arg_help=false; \
  arg_command=commit; \
  values=(); \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -a|--amend) arg_command=\"commit --amend --no-edit\" ;; \
      -e|--edit) arg_command=\"commit --amend\" ;; \
      *) values+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git commitx [<options>] [<message>]'; \
    echo '   Or: git commitx --amend [<options>]'; \
    echo '   Or: git commitx --edit [<options>] [<message>]'; \
    echo 'Options:'; \
    echo '  -a, --amend     Amend the previous commit with the new changes and reuse the previous commit message.'; \
    echo '  -e, --edit      Amend the previous commit with the new changes and edit the previous commit message.'; \
    echo '  ... See `git commit --help` for more options.'; \
    return 0; \
  fi; \
  \
  git $arg_command \"${values[@]}\"; \
}; f"
c = commitx
commitx-with-message = "!f() {\
  arg_help=false; \
  arg_command=\"commitx --message\"; \
  arg_not_allow_amend=false; \
  values=(); \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -e|--edit) arg_command=\"commitx --edit --message\" ;; \
      -a|--amend) arg_not_allow_amend=true ;; \
      *) values+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git commitx-with-message [options] <category> [<scope>] <subject_and_body>'; \
    echo '   Or: git commitx-with-message --edit'; \
    echo 'Options:'; \
    echo '  -e, --edit     Amend the previous commit with the new changes and edit the previous commit message.'; \
    echo '  ... See `git commitx --?` for more options.'; \
    return 0; \
  fi; \
  \
  if \"$arg_not_allow_amend\"; then \
    echo 'Cannot use --amend option together with command `commitx-with-message`.';\
    echo 'Command `commitx-with-message` is designed to always require a new commit message, while --amend is used to reuse the previous commit message. They are conflicting.'; \
    return 1; \
  fi; \
  \
  if [[ ${#values[@]} -eq 3 ]]; then \
    git $arg_command \"${values[0]}(${values[1]}): ${values[2]}\"; \
  elif [[ ${#values[@]} -eq 2 ]]; then \
    git $arg_command \"${values[0]}: ${values[1]}\"; \
  else \
    echo 'Please provide a valid conventional commit message.'; \
    return 1; \
  fi; \
}; f"
cm = commitx-with-message
uncommit = reset --soft HEAD^ # Back to the staging area
uc = uncommit
commit-work-in-progress = "!git commitx-with-message chore 'wip'"
cwip = commit-work-in-progress
commit-readme = "!git commitx-with-message docs 'update README.md'"
crdm = commit-readme
commit-dependencies = "!git commitx-with-message chore 'update dependencies'"
cdep = commit-dependencies
# @aliasGroup Work with Branches
b = branch
# @alias Branch Delete
# @description Delete branch with more flexible options.
# @parameters One branch name and optional flags:
#   - `-o` or `--origin`: Delete the branch from origin remote only.
#   - `-a` or `--all`: Delete the branch from both local and origin remote.
#   - `-f` or `--force`: Force delete the local branch.
#   - If neither `-o` / `--origin` nor `-a` / `--all` is provided, delete the branch from local only.
branch-delete = "!f() { \
  arg_help=false; \
  arg_range=local; \
  arg_force=false; \
  branch_name=""; \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -o|--origin) arg_range=origin ;; \
      -a|--all) arg_range=all ;; \
      -f|--force) arg_force=true ;; \
      *) branch_name=\"$arg\" ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git branch-delete [options] <branch-name>'; \
    echo 'Options:'; \
    echo '  -o, --origin    Delete the branch from origin remote only.'; \
    echo '  -a, --all       Delete the branch from both local and origin remote.'; \
    echo '  -f, --force     Force delete the local branch.'; \
    return 0; \
  fi; \
  \
  if [[ -z \"$branch_name\" ]]; then \
    echo 'Please provide a branch name to delete.'; \
    return 1; \
  fi; \
  \
  if [[ \"$arg_range\" == all ]]; then \
    if [[ \"$arg_force\" == true ]]; then \
      git branch --delete --force \"$branch_name\"; \
    else \
      git branch --delete \"$branch_name\"; \
    fi; \
    git push origin \":refs/heads/$branch_name\"; \
  elif [[ \"$arg_range\" == origin ]]; then \
    git push origin \":refs/heads/$branch_name\"; \
  else \
    if [[ \"$arg_force\" == true ]]; then \
      git branch --delete --force \"$branch_name\"; \
    else \
      git branch --delete \"$branch_name\"; \
    fi; \
  fi; \
}; f"
bx = branch-delete
# @aliasGroup Stash
stashx = "!f() { \
  arg_help=false; \
  arg_command=stash; \
  values=(); \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -l|--list) arg_command=\"stash list\" ;; \
      -s|--show) arg_command=\"stash show\" ;; \
      -a|--apply) arg_command=\"stash apply\" ;; \
      -p|--pop) arg_command=\"stash pop\" ;; \
      -x|--drop) arg_command=\"stash drop\" ;; \
      *) values+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git stashx [options] [<message>]'; \
    echo 'Options:'; \
    echo '  -l, --list      List all stashes.'; \
    echo '  -s, --show      Show the changes recorded in the stash as a diff between the stashed state and its original parent.'; \
    echo '  -a, --apply     Apply the changes recorded in the stash to the working directory.'; \
    echo '  -p, --pop       Apply the changes recorded in the stash to the working directory and remove the stash from the stash list.'; \
    echo '  -x, --drop      Remove a single stash from the stash list.'; \
    echo '  ... See `git $arg_command --help` for more options.'; \
    return 0; \
  fi; \
  \
  git $arg_command \"${values[@]}\"; \
}; f"
s = stashx
# @aliasGroup Switch
w = switch
# @aliasGroup Merge
# Notice, like commit, multiple `-m` options will be concatenated with `\n\n` as separator to form the final merge commit message.
mergex = "!f() { \
  arg_help=false; \
  arg_command=\"merge --no-ff\"; \
  values=(); \
  \
  for arg in \"$@\"; do \
    case \"$arg\" in \
      -\\?|--\\?) arg_help=true ;; \
      -z|--abort) arg_command=\"merge --abort\" ;; \
      -c|--continue) arg_command=\"merge --continue\" ;; \
      *) values+=(\"$arg\") ;; \
    esac; \
  done; \
  \
  if \"$arg_help\"; then \
    echo 'Usage: git mergex [<options>] [<commit>]'; \
    echo '   Or: git mergex --abort'; \
    echo '   Or: git mergex --continue'; \
    echo 'Options:'; \
    echo '  -z, --abort     Abort the merge operation.'; \
    echo '  -c, --continue  Continue the merge operation.'; \
    echo '  ... See `git merge --help` for more options.'; \
    return 0; \
  fi; \
  \
  if [[ \"$arg_command\" == \"merge --no-ff\" ]]; then \
    current_branch=$(git branch --show-current); \
    merge_branches=$(echo ${values[*]} | awk -v OFS=\", \" '{ $1=$1; print }'); \
    if git $arg_command --message \"chore: merge $merge_branches into $current_branch\" \"$@\"; then \
      echo \"Merging \"$merge_branches\" into current $current_branch with default message...\"; \
    fi; \
  else \
    git $arg_command; \
  fi; \
}; f"
m = mergex
mz = mergex --abort
mc = mergex --continue
# @aliasGroup Rebase
n = rebase
nz = rebase --abort
nc = rebase --continue
# @aliasGroup Reset
rs = reset
# @aliasGroup Revert
rv = revert
rvz = revert --abort
rvc = revert --continue
# @aliasGroup Cherry-pick
cp = cherry-pick
cpz = cherry-pick --abort
cpc = cherry-pick --continue
# @aliasGroup Tag
tagx = "!f() { \
  declare -i arg_count=0; \
  declare -i value_count=0; \
  \
  for arg in \"$@\"; do \
    if [[ \"$arg\" =~ ^-.* ]]; then \
      arg_count=arg_count+1; \
    else \
      value_count=value_count+1; \
    fi; \
  done; \
  \
  if [[ \"$arg_count\" -eq 0 ]]; then \
    if [[ \"value_count\" -ge 2 ]]; then \
      git tag --annotate \"$1\" --message \"$2\"; \
    elif [[ \"value_count\" -ge 1 ]]; then  \
      git tag --annotate \"$1\" --message \"$1\"; \
    fi; \
  else \
    git tag \"$@\"; \
  fi; \
}; f"
t = tagx
tag-delete = "!f() { \
  arg_range=local; \
  tag_name=""; \
  \
  for arg in \"$@\"; do \
    case $arg in \
      -o|--origin) arg_range=origin ;; \
      -a|--all) arg_range=all ;; \
      *) tag_name=\"$arg\" ;; \
    esac; \
  done; \
  \
  if [[ -z \"$tag_name\" ]]; then \
    echo 'Please provide a tag name to delete.'; \
    return 1; \
  fi; \
  \
  if [ \"$arg_range\" == all ]; then \
    git tag --delete \"$tag_name\"; \
    git push origin \":refs/tags/$tag_name\"; \
  elif [ \"$arg_range\" == origin ]; then \
    git push origin \":refs/tags/$tag_name\"; \
  else \
    git tag --delete \"$tag_name\"; \
  fi; \
}; f"
tx = tag-delete
# @aliasGroup Remote
r = remote
remote-new = "!f() { \
  if [ -z \"$2\" ]; then \
    git remote add origin \"$1\"; \
  else \
    git remote add \"$1\" \"$2\"; \
  fi; \
}; f"
rn = remote-new
remote-remove = remote remove
rx = remote-remove
# @aliasGroup Fetch
f = fetch
# @aliasGroup Pull
l = pull
# @aliasGroup Push
p = push
push-delete = push --delete
px = push-delete
# @aliasGroup Log
graph = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
logs = log HEAD --stat
log1 = log -1 HEAD --stat
# @aliasGroup Aliases
aliases = "!git config --get-regexp ^alias\\. | sed -e s/^alias\\.// -e s/\\ /\\ =\\ /"

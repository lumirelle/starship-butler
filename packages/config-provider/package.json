{
  "name": "starship-butler-config-provider",
  "type": "module",
  "version": "5.0.2",
  "description": "Config provider of starship butler.",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/starship-butler#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/starship-butler.git"
  },
  "bugs": "https://github.com/lumirelle/starship-butler/issues",
  "keywords": [
    "config-butler",
    "config-manager",
    "starship-butler"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./command/set": {
      "import": {
        "types": "./dist/command/set/index.d.ts",
        "default": "./dist/command/set/index.js"
      }
    },
    "./command/preset": {
      "import": {
        "types": "./dist/command/preset/index.d.ts",
        "default": "./dist/command/preset/index.js"
      }
    },
    "./command/utils": {
      "import": {
        "types": "./dist/command/utils/index.d.ts",
        "default": "./dist/command/utils/index.js"
      }
    },
    "./constants": {
      "import": {
        "types": "./dist/constants.d.ts",
        "default": "./dist/constants.js"
      }
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "assets",
    "dist"
  ],
  "scripts": {
    "pubcheck": "bun run --parallel 'attw --pack --profile esm-only' publint"
  },
  "dependencies": {
    "@clack/prompts": "catalog:prod",
    "consola": "catalog:prod",
    "pathe": "catalog:prod",
    "starship-butler-types": "workspace:*",
    "starship-butler-utils": "workspace:*",
    "tinyexec": "catalog:prod",
    "tinyglobby": "catalog:prod"
  },
  "devDependencies": {
    "@antfu/utils": "catalog:inlined"
  }
}

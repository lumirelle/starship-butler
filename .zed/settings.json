{
  // Code Quality
  "formatter": [],
  "prettier": { "allowed": false },
  "code_actions_on_format": {
    "source.fixAll.oxc": true,
    "source.fixAll.eslint": true,
    "source.organizeImports": false
  },
  "lsp": {
    "eslint": {
      "settings": {
        "runtime": "bun",
        "execArgv": ["-b"],
        "validate": [
          "javascript",
          "javascriptreact",
          "typescript",
          "typescriptreact",
          "vue",
          "html",
          "markdown",
          "json",
          "jsonc",
          "yaml",
          "toml",
          "xml",
          "css",
          "postcss",
          "scss",
          "sass",
          "less"
        ]
      }
    }
  },

  // File associations
  "file_types": {
    "JSONC": ["**/*.json"]
  }
}

      },
      "prod": {
        "@clack/prompts": "^1.4.0",
        "c12": "^4.0.0-beta.5",
        "cac": "^7.0.0",
        "consola": "^3.4.2",
        "defu": "^6.1.7",
        "pathe": "^2.0.3",
        "rc9": "^3.0.1",

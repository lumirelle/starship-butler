{
  "type": "module",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "bunup --watch",
    "build": "bunup --exports",
    "start": "bun run --cwd packages/core start",
    "docs": "bun run --cwd docs docs:dev",
    "docs:build": "bun run --cwd docs docs:build",
    "docs:start": "bun run --cwd docs docs:start",
    "play": "bun run --cwd playground play",
    "lint": "bun run --parallel oxlint eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "typecheck": "tsc -b",
    "unused": "knip-bun",
    "pubcheck": "bun run --parallel --filter '*' pubcheck",
    "check": "bun run --parallel lint typecheck unused pubcheck",
    "test": "bun test",
    "prerelease": "bun run build && bun run --parallel check test",
    "release": "bumpp --all --recursive --execute \"bun update --lockfile-only starship-butler\" # See https://github.com/oven-sh/bun/issues/18906 and https://github.com/oven-sh/bun/issues/20477"
  },
  "workspaces": {
    "packages": [
      "docs",
      "playground",
      "packages/*",
      "examples/*"
    ],
    "catalogs": {
      "prod": {
        "@clack/prompts": "^1.1.0",
        "c12": "^4.0.0-beta.4",
        "consola": "^3.4.2",
        "defu": "^6.1.4",
        "pathe": "^2.0.3",
        "rc9": "^3.0.0",
        "tinyexec": "^1.0.4",
        "tinyglobby": "^0.2.15"
      },
      "inlined": {
        "@antfu/utils": "^9.3.0",
        "cac": "^7.0.0"
      },
      "dev": {
        "bumpp": "^11.0.1",
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657",
        "typescript": "^5.9.3"
      },
      "types": {
        "@types/bun": "^1.3.11"
      },
      "build": {
        "bunup": "^0.16.31"
      },
      "check": {
        "@antfu/eslint-config": "^7.7.3",
        "@arethetypeswrong/cli": "^0.18.2",
        "@lumirelle/oxlint-config": "^0.0.5",
        "eslint": "^10.0.3",
        "eslint-plugin-oxlint": "^1.56.0",
        "knip": "^6.0.0",
        "nano-staged": "^0.9.0",
        "oxlint": "^1.56.0",
        "oxlint-tsgolint": "^0.17.1",
        "publint": "^0.3.18"
      },
      "test": {
        "vite": "^8.0.1",
        "vitest-package-exports": "^1.2.0"
      },
      "docs": {
        "@iconify-json/svg-spinners": "^1.2.4",
        "@shikijs/vitepress-twoslash": "^4.0.2",
        "@unocss/reset": "^66.6.7",
        "@vueuse/core": "^14.2.1",
        "floating-vue": "^5.2.2",
        "pinia": "^3.0.4",
        "unocss": "^66.6.7",
        "unplugin-vue-components": "^31.0.0",
        "vite-tsconfig-paths": "^6.1.1",
        "vitepress": "^2.0.0-alpha.17",
        "vitepress-plugin-group-icons": "^1.7.1"
      }
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@arethetypeswrong/cli": "catalog:check",
    "@lumirelle/oxlint-config": "catalog:check",
    "@types/bun": "catalog:types",
    "bumpp": "catalog:dev",
    "bunup": "catalog:build",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "publint": "catalog:check",
    "simple-git-hooks": "catalog:dev",
    "starship-butler": "workspace:*",
    "starship-butler-config-provider": "workspace:*",
    "starship-butler-types": "workspace:*",
    "starship-butler-utils": "workspace:*",
    "typescript": "catalog:dev",
    "vite": "catalog:test",
    "vitest-package-exports": "catalog:test"
  },
  "overrides": {
    "vite": "^8.0.1"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint",
      "eslint"
    ]
  }
}

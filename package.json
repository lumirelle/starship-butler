{
  "type": "module",
  "version": "6.0.1",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "bun run --parallel --filter '*' dev",
    "count-vscode-extensions": "bun run ./scripts/count-vscode-extensions.ts",
    "build": "bun run --filter '*' build",
    "start": "bun run --cwd packages/core start",
    "docs": "bun run --cwd docs docs:dev",
    "docs:build": "bun run --cwd docs docs:build",
    "docs:start": "bun run --cwd docs docs:start",
    "play": "bun run --cwd playground play",
    "lint": "bun run --parallel oxlint eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "pretypecheck": "bun run build",
    "typecheck": "bun run --filter '*' typecheck",
    "unused": "knip-bun",
    "check": "bun run --parallel lint typecheck unused",
    "pretest": "bun run build",
    "test": "bun test --isolate",
    "prerelease": "bun run --parallel check test",
    "release": "bumpp --all --recursive --execute \"bun run ./scripts/update-lockfile.sh\" # See https://github.com/oven-sh/bun/issues/18906 and https://github.com/oven-sh/bun/issues/20477"
  },
  "workspaces": {
    "packages": [
      "docs",
      "playground",
      "packages/*",
      "examples/*"
    ],
    "catalogs": {
      "dev": {
        "bumpp": "^11.1.0"
      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.4",
        "@types/node": "^25.9.0",
        "bun-types": "^1.3.14",
        "typescript": "^6.0.3"
      },
      "build": {
        "std-env": "^4.1.0",
        "tsdown": "^0.22.0"
      },
      "inlined": {
        "@antfu/utils": "^9.3.0"
      },
      "prod": {
        "@clack/prompts": "^1.4.0",
        "c12": "^4.0.0-beta.5",
        "cac": "^7.0.0",
        "consola": "^3.4.2",
        "defu": "^6.1.7",
        "pathe": "^2.0.3",
        "rc9": "^3.0.1",
        "tinyexec": "^1.1.2",
        "tinyglobby": "^0.2.16"
      },
      "docs": {
        "@iconify-json/svg-spinners": "^1.2.4",
        "@shikijs/vitepress-twoslash": "^4.0.2",
        "@unocss/reset": "^66.6.8",
        "@vueuse/core": "^14.3.0",
        "floating-vue": "^5.2.2",
        "pinia": "^3.0.4",
        "unocss": "^66.6.8",
        "unplugin-vue-components": "^32.0.0",
        "vite": "^8.0.13",
        "vite-tsconfig-paths": "^6.1.1",
        "vitepress": "^2.0.0-alpha.17",
        "vitepress-plugin-group-icons": "^1.7.5",
        "vue": "^3.5.34"
      },
      "check": {
        "@antfu/eslint-config": "^9.0.0",
        "@arethetypeswrong/core": "^0.18.2",
        "@lumirelle/oxlint-config": "^0.5.0",
        "eslint": "^10.4.0",
        "eslint-plugin-oxlint": "^1.65.0",
        "knip": "^6.14.1",
        "nano-staged": "^1.0.2",
        "oxlint": "^1.65.0",
        "oxlint-tsgolint": "^0.23.0",
        "publint": "^0.3.21",
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657"
      },
      "test": {
        "tsnapi": "^0.3.3"
      }
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@arethetypeswrong/core": "catalog:check",
    "@lumirelle/oxlint-config": "catalog:check",
    "@lumirelle/tsconfig": "catalog:types",
    "@types/node": "catalog:types",
    "bumpp": "catalog:dev",
    "bun-types": "catalog:types",
    "consola": "catalog:prod",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "publint": "catalog:check",
    "simple-git-hooks": "catalog:check",
    "std-env": "catalog:build",
    "tsdown": "catalog:build",
    "tsnapi": "catalog:test",
    "typescript": "catalog:types"
  },
  "overrides": {
    "fflate": "0.8.2",
    "typescript": "catalog:types",
    "vite": "catalog:docs",
    "vue": "catalog:docs"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint --no-error-on-unmatched-pattern",
      "eslint"
    ]
  }
}

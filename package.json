{
  "type": "module",
  "version": "8.0.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "bun": "*"
  },
  "devEngines": {
    "runtime": {
      "name": "bun",
      "version": ">1.0.0"
    },
    "packageManager": {
      "name": "aube",
      "version": "1.17.0"
    }
  },
  "scripts": {
    "prepare": "mise run prepare",
    "count-vscode-extensions": "bun run ./scripts/count-vscode-extensions.ts",
    "dev": "mise run //packages/...:dev",
    "build": "mise run //packages/...:build",
    "start": "mise run //packages/core:start",
    "docs:dev": "mise run //docs:dev",
    "docs:build": "mise run //docs:build",
    "docs:start": "mise run //docs:start",
    "play": "mise run //playground:play",
    "lint:oxlint": "oxlint",
    "lint:eslint": "eslint",
    "lint:fix:oxlint": "oxlint --fix",
    "lint:fix:eslint": "eslint --fix",
    "typecheck": "mise run //packages/...:typecheck",
    "unused": "knip-bun",
    "test:watch": "vitest",
    "test": "vitest run",
    "release": "bumpp --all --recursive"
  },
  "workspaces": {
    "packages": [
      "docs",
      "playground",
      "packages/*",
      "examples/*"
    ],
    "catalogs": {
      "dev": {
        "bumpp": "^11.1.0"
      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.4",
        "@types/node": "^25.9.1",
        "bun-types": "^1.3.14",
        "typescript": "^6.0.3"
      },
      "build": {
        "tsdown": "^0.22.1"
      },
      "inlined": {
        "@antfu/utils": "^9.3.0"
      },
      "prod": {
        "@clack/prompts": "^1.5.0",
        "c12": "^4.0.0-beta.5",
        "cac": "^7.0.0",
        "consola": "^3.4.2",
        "defu": "^6.1.7",
        "pathe": "^2.0.3",
        "rc9": "^3.0.1",
        "tinyexec": "^1.2.4",
        "tinyglobby": "^0.2.17"
      },
      "docs": {
        "@iconify-json/svg-spinners": "^1.2.4",
        "@shikijs/vitepress-twoslash": "^4.2.0",
        "@unocss/reset": "^66.7.0",
        "@vueuse/core": "^14.3.0",
        "floating-vue": "^5.2.2",
        "oxc-minify": "^0.134.0",
        "pinia": "^3.0.4",
        "unocss": "^66.7.0",
        "unplugin-vue-components": "^32.1.0",
        "vite": "^8.0.16",
        "vitepress": "^2.0.0-alpha.17",
        "vitepress-plugin-group-icons": "^1.7.5",
        "vue": "^3.5.35"
      },
      "check": {
        "@antfu/eslint-config": "^9.0.0",
        "@arethetypeswrong/core": "^0.18.3",
        "@lumirelle/oxlint-config": "^0.7.0",
        "eslint": "^10.4.1",
        "eslint-plugin-oxlint": "^1.68.0",
        "knip": "^6.15.0",
        "nano-staged": "^1.0.2",
        "oxlint": "^1.68.0",
        "oxlint-tsgolint": "^0.23.0",
        "publint": "^0.3.21"
      },
      "test": {
        "std-env": "^4.1.0",
        "tsnapi": "^0.3.3",
        "vitest": "^4.1.8"
      }
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@lumirelle/oxlint-config": "catalog:check",
    "@lumirelle/tsconfig": "catalog:types",
    "@types/node": "catalog:types",
    "bumpp": "catalog:dev",
    "bun-types": "catalog:types",
    "consola": "catalog:prod",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "tsnapi": "catalog:test",
    "typescript": "catalog:types",
    "vitest": "catalog:test"
  },
  "overrides": {
    "typescript": "catalog:types",
    "vite": "catalog:docs",
    "vue": "catalog:docs"
  },
  "nano-staged": {
    "*": [
      "oxlint --no-error-on-unmatched-pattern",
      "eslint"
    ]
  }
}
